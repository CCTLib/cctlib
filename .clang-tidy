# Conservative clang-tidy config for CCTLib.
#
# Scope: catch real bugs and performance issues on the code as-it-stands,
# without demanding wholesale rewrites. Style-only families (readability,
# modernize, google, cppcoreguidelines, hicpp, fuchsia, llvm) are disabled.
#
# HeaderFilterRegex only reports on our own headers under src/, clients/,
# tests/. Diagnostics from Pin's musl/libc++ headers, sparsehash, and
# nlohmann/json are suppressed as non-user code.
#
# The Pin runtime include paths and macros needed to actually parse
# pin.H / musl / libc++ are not in this file -- they are supplied by
# `make lint`, which knows $(PIN_ROOT). Invoking clang-tidy directly on
# a Pin-using file will therefore fail to parse; use `make lint`.

Checks: >-
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-macro-parentheses,
  -bugprone-reserved-identifier,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-assignment-in-if-condition,
  -bugprone-forwarding-reference-overload,
  -bugprone-branch-clone,
  performance-*,
  -performance-avoid-endl,
  -performance-no-int-to-ptr,
  readability-*,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity,
  -readability-identifier-length,
  -readability-implicit-bool-conversion,
  -readability-uppercase-literal-suffix,
  -readability-braces-around-statements,
  -readability-isolate-declaration,
  -readability-convert-member-functions-to-static,
  -readability-avoid-const-params-in-decls,
  -readability-named-parameter,
  -readability-else-after-return,
  -readability-static-accessed-through-instance,
  modernize-*,
  -modernize-use-trailing-return-type,
  -modernize-use-nodiscard,
  -modernize-avoid-c-arrays,
  -modernize-avoid-bind,
  -modernize-use-auto,
  -modernize-use-default-member-init,
  -modernize-return-braced-init-list,
  -modernize-loop-convert,
  -modernize-raw-string-literal,
  -modernize-concat-nested-namespaces,
  -modernize-use-emplace,
  -modernize-deprecated-headers,
  -modernize-macro-to-enum,
  clang-analyzer-core.*,
  clang-analyzer-cplusplus.*,
  clang-analyzer-deadcode.*,
  clang-analyzer-security.*,
  clang-analyzer-unix.*,
  misc-redundant-expression,
  misc-unused-using-decls

# bugprone-branch-clone is disabled globally. Triage found the majority of
# hits in this codebase are intentional: (a) large hand-written register
# dispatch switches where each case sets the same fields to different
# values and the analyzer sees the structural similarity as duplication,
# (b) two-level page-table init code where an if/else pair legitimately
# repeats an mmap statement, and (c) stubbed callbacks awaiting future
# implementation. The few real duplicate branches surface again as soon
# as this is re-enabled -- flip it back on when doing a broader
# perf/refactor pass.

WarningsAsErrors: ''
HeaderFilterRegex: '^.*/(src|clients|tests)/[^/]+\.(H|h|hpp)$'
FormatStyle: none

CheckOptions:
  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: 'false'
